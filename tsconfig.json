{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@mrmeg/expo-ui": [
        "./packages/ui/src/index.ts"
      ],
      "@mrmeg/expo-ui/components": [
        "./packages/ui/src/components/index.ts"
      ],
      "@mrmeg/expo-ui/components/*": [
        "./packages/ui/src/components/*"
      ],
      "@mrmeg/expo-ui/constants": [
        "./packages/ui/src/constants/index.ts"
      ],
      "@mrmeg/expo-ui/hooks": [
        "./packages/ui/src/hooks/index.ts"
      ],
      "@mrmeg/expo-ui/state": [
        "./packages/ui/src/state/index.ts"
      ],
      "@mrmeg/expo-ui/lib": [
        "./packages/ui/src/lib/index.ts"
      ]
    },
    "noImplicitAny": false,
    "jsx": "react-native",
    "types": [
      "react-native",
      "node",
      "jest"
    ],
    "skipLibCheck": true,
    "module": "esnext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
  ]
}
