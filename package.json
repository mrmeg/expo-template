{
  "name": "template",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node ./server/index.ts",
    "start-local": "bun --env-file=.env ./server/index.ts",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:scan": "expo start --web",
    "scan:showcase": "node -e \"const { spawnSync } = require('node:child_process'); const port = process.env.EXPO_DEV_SERVER_PORT || process.env.PORT || '8081'; spawnSync('open', ['http://localhost:' + port + '/showcase?scan'], { stdio: 'inherit' });\"",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 expo export -p web --output-dir dist",
    "build-web": "NODE_OPTIONS=--max-old-space-size=8192 bun x expo export -p web --output-dir dist --dump-sourcemap",
    "build-sourcemap": "bun run build-web",
    "view-sourcemap": "bun x source-map-explorer 'dist/client/_expo/static/js/web/*.js' --no-border-checks",
    "analyze": "bun run build-web && bun run view-sourcemap",
    "serve:ssr": "expo serve",
    "bundle-size": "node scripts/check-bundle-size.js",
    "check:features": "node scripts/check-feature-isolation.js",
    "ui:typecheck": "bun run --cwd packages/ui typecheck",
    "ui:test": "bun run --cwd packages/ui test",
    "ui:build": "bun run --cwd packages/ui build",
    "ui:pack": "bun run --cwd packages/ui publish:dry-run",
    "ui:consumer-smoke": "node scripts/check-ui-package-consumer.mjs",
    "ui:release": "node scripts/release-ui-package.mjs",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage --forceExit",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "generate": "npx tsx scripts/generate.ts"
  },
  "dependencies": {
    "@aws-amplify/react-native": "^1.3.3",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@expo/metro-runtime": "~55.0.10",
    "@hookform/resolvers": "^5.2.2",
    "@mrmeg/expo-ui": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/core": "^7.17.2",
    "@react-navigation/native": "^7.1.33",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.100.9",
    "aws-amplify": "^6.16.4",
    "aws-jwt-verify": "^5.1.1",
    "expo": "~55.0.19",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.13",
    "expo-router": "~55.0.13",
    "expo-server": "~55.0.8",
    "expo-splash-screen": "~55.0.19",
    "expo-video": "~55.0.15",
    "expo-video-thumbnails": "~55.0.14",
    "expo-web-browser": "~55.0.14",
    "heic2any": "^0.0.4",
    "i18next": "^26.0.8",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.4",
    "semver": "^7.7.4",
    "stripe": "^22.1.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "globals": "^17.6.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "morgan": "^1.10.1",
    "pretty-format": "30.3.0",
    "react-test-renderer": "19.2.0",
    "reactotron-react-native": "^5.1.18",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "baseline-browser-mapping": "^2.10.27"
  },
  "private": true
}
