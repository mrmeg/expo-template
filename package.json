{
  "name": "template",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "bun ./server.bun.ts",
    "start-local": "bun --env-file=.env ./server.bun.ts",
    "start:express": "node ./server/index.ts",
    "start-local:express": "bun --env-file=.env ./server/index.ts",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:scan": "expo start --web",
    "scan:showcase": "node -e \"const { spawnSync } = require('node:child_process'); const port = process.env.EXPO_DEV_SERVER_PORT || process.env.PORT || '8081'; spawnSync('open', ['http://localhost:' + port + '/showcase?scan'], { stdio: 'inherit' });\"",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 expo export -p web --output-dir dist",
    "build-web": "NODE_OPTIONS=--max-old-space-size=8192 bun x expo export -p web --output-dir dist --dump-sourcemap",
    "build-sourcemap": "bun run build-web",
    "view-sourcemap": "bun x source-map-explorer 'dist/client/_expo/static/js/web/*.js' --no-border-checks",
    "analyze": "bun run build-web && bun run view-sourcemap",
    "serve:ssr": "expo serve",
    "bundle-size": "node scripts/check-bundle-size.js",
    "check:features": "node scripts/check-feature-isolation.js",
    "ui:typecheck": "bun run --cwd packages/ui typecheck",
    "ui:test": "bun run --cwd packages/ui test",
    "ui:build": "bun run --cwd packages/ui build",
    "ui:pack": "bun run --cwd packages/ui publish:dry-run",
    "ui:consumer-smoke": "node scripts/check-ui-package-consumer.mjs",
    "ui:release": "node scripts/release-ui-package.mjs",
    "media:typecheck": "bun run --cwd packages/media typecheck",
    "media:test": "bun run --cwd packages/media test",
    "media:build": "bun run --cwd packages/media build",
    "media:pack": "bun run --cwd packages/media publish:dry-run",
    "media:consumer-smoke": "node scripts/check-media-package-consumer.mjs",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage --forceExit",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "generate": "npx tsx scripts/generate.ts"
  },
  "dependencies": {
    "@aws-amplify/react-native": "^1.3.3",
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@expo/metro-runtime": "~56.0.8",
    "@hookform/resolvers": "^5.2.2",
    "@mrmeg/expo-media": "workspace:*",
    "@mrmeg/expo-ui": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/core": "^7.17.4",
    "@react-navigation/native": "^7.2.4",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.100.10",
    "aws-amplify": "^6.17.0",
    "aws-jwt-verify": "^5.1.1",
    "expo": "~56.0.0-preview.12",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.11",
    "expo-crypto": "~56.0.3",
    "expo-file-system": "~56.0.5",
    "expo-font": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image-manipulator": "~56.0.9",
    "expo-image-picker": "~56.0.9",
    "expo-linking": "~56.0.8",
    "expo-localization": "~56.0.4",
    "expo-router": "~56.2.1",
    "expo-server": "~56.0.2",
    "expo-splash-screen": "~56.0.7",
    "expo-system-ui": "~56.0.4",
    "expo-video": "~56.1.1",
    "expo-video-thumbnails": "~56.0.3",
    "expo-web-browser": "~56.0.4",
    "heic2any": "^0.0.4",
    "i18next": "^26.2.0",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "semver": "^7.8.0",
    "stripe": "^22.1.1",
    "ulid": "^3.0.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^25.8.0",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "globals": "^17.6.0",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.3",
    "morgan": "^1.10.1",
    "pretty-format": "30.4.1",
    "react-test-renderer": "19.2.3",
    "reactotron-react-native": "^5.1.18",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "baseline-browser-mapping": "^2.10.27"
  },
  "private": true
}
