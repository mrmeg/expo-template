{
  "name": "template",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "bun ./server.bun.ts",
    "start-local": "bun --env-file=.env ./server.bun.ts",
    "start:express": "node ./server/index.ts",
    "start-local:express": "bun --env-file=.env ./server/index.ts",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:scan": "expo start --web",
    "scan:showcase": "node -e \"const { spawnSync } = require('node:child_process'); const port = process.env.EXPO_DEV_SERVER_PORT || process.env.PORT || '8081'; spawnSync('open', ['http://localhost:' + port + '/showcase?scan'], { stdio: 'inherit' });\"",
    "gen:templates": "npx tsx scripts/generate-template-registry.ts",
    "gen:templates:check": "npx tsx scripts/generate-template-registry.ts --check",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 expo export -p web --output-dir dist",
    "build-web": "NODE_OPTIONS=--max-old-space-size=8192 expo export -p web --output-dir dist --dump-sourcemap",
    "build-sourcemap": "bun run build-web",
    "view-sourcemap": "bun x source-map-explorer 'dist/client/_expo/static/js/web/*.js' --no-border-checks",
    "view-sourcemap:gzip": "bun x source-map-explorer 'dist/client/_expo/static/js/web/*.js' --no-border-checks --gzip",
    "analyze": "bun run build-web && bun run view-sourcemap",
    "analyze:gzip": "bun run build-web && bun run view-sourcemap:gzip",
    "serve:ssr": "expo serve",
    "bundle-size": "node scripts/check-bundle-size.js",
    "check:features": "node scripts/check-feature-isolation.js",
    "docs:llms": "node scripts/build-llms-full.mjs",
    "docs:llms:check": "node scripts/build-llms-full.mjs --check",
    "ui:typecheck": "bun run --cwd packages/ui typecheck",
    "ui:test": "bun run --cwd packages/ui test",
    "ui:build": "bun run --cwd packages/ui build",
    "ui:pack": "bun run --cwd packages/ui publish:dry-run",
    "ui:consumer-smoke": "node scripts/check-ui-package-consumer.mjs",
    "ui:release": "node scripts/release-ui-package.mjs",
    "media:typecheck": "bun run --cwd packages/media typecheck",
    "media:test": "bun run --cwd packages/media test",
    "media:build": "bun run --cwd packages/media build",
    "media:pack": "bun run --cwd packages/media publish:dry-run",
    "media:consumer-smoke": "node scripts/check-media-package-consumer.mjs",
    "media:release": "node scripts/release-media-package.mjs",
    "packages:peer-check": "node scripts/check-package-peer-compatibility.mjs",
    "packages:compatibility": "node scripts/check-package-consumer-profile.mjs",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage --forceExit",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "generate": "npx tsx scripts/generate.ts"
  },
  "dependencies": {
    "@aws-amplify/react-native": "^1.3.3",
    "@clerk/backend": "^3.11.1",
    "@clerk/clerk-expo": "^2.19.31",
    "@expo/metro-runtime": "~57.0.7",
    "@expo/ui": "~57.0.7",
    "@hookform/resolvers": "^5.4.0",
    "@mrmeg/expo-media": "workspace:*",
    "@mrmeg/expo-ui": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.101.2",
    "aws-amplify": "^6.18.0",
    "aws-jwt-verify": "^5.2.1",
    "expo": "~57.0.8",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.7",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.8",
    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-manipulator": "~57.0.6",
    "expo-image-picker": "~57.0.6",
    "expo-linking": "~57.0.4",
    "expo-localization": "~57.0.1",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-server": "~57.0.1",
    "expo-splash-screen": "~57.0.5",
    "expo-system-ui": "~57.0.1",
    "expo-video": "~57.0.2",
    "expo-web-browser": "~57.0.2",
    "heic2any": "^0.0.4",
    "i18next": "^26.3.5",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.81.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "semver": "^7.8.5",
    "stripe": "^22.3.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/runtime": "^8.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@sentry/cli": "3.6.0",
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "29.5.14",
    "@types/node": "^26.1.1",
    "@types/react": "~19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "expo-atlas": "^0.4.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "globals": "^17.7.0",
    "jest": "~29.7.0",
    "jest-expo": "~57.0.2",
    "morgan": "^1.11.0",
    "pretty-format": "30.4.1",
    "react-test-renderer": "19.2.3",
    "reactotron-react-native": "^5.2.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "baseline-browser-mapping": "^2.10.27"
  },
  "license": "MIT",
  "private": true
}
