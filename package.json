{
  "name": "template",
  "main": "expo-router/entry",
  "version": "0.0.1",
  "scripts": {
    "start": "node ./server/index.ts",
    "start-local": "bun --env-file=.env ./server/index.ts",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:scan": "expo start --web",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 expo export -p web --output-dir dist",
    "build-web": "npx expo export -p web",
    "build-sourcemap": "expo export -p web --output-dir dist --dump-sourcemap",
    "view-sourcemap": "npx source-map-explorer 'dist/client/**/*.js' --no-border-checks",
    "analyze": "expo export -p web --output-dir dist --dump-sourcemap && npx source-map-explorer 'dist/client/**/*.js' --no-border-checks",
    "serve:ssr": "expo serve",
    "bundle-size": "node scripts/check-bundle-size.js",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage --forceExit",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "generate": "npx tsx scripts/generate.ts"
  },
  "dependencies": {
    "@aws-amplify/react-native": "^1.3.3",
    "@aws-sdk/client-s3": "^3.1030.0",
    "@aws-sdk/s3-request-presigner": "^3.1030.0",
    "@expo-google-fonts/lato": "^0.4.1",
    "@expo/metro-runtime": "~55.0.9",
    "@ffmpeg/util": "^0.12.2",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.33",
    "@rn-primitives/accordion": "^1.4.0",
    "@rn-primitives/alert-dialog": "^1.4.0",
    "@rn-primitives/checkbox": "^1.4.0",
    "@rn-primitives/collapsible": "^1.4.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/dropdown-menu": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/popover": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/radio-group": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@rn-primitives/toggle": "^1.4.0",
    "@rn-primitives/toggle-group": "^1.4.0",
    "@rn-primitives/tooltip": "^1.4.0",
    "@rn-primitives/types": "^1.4.0",
    "@sentry/react-native": "~7.11.0",
    "@tanstack/react-query": "^5.99.0",
    "aws-amplify": "^6.16.4",
    "aws-jwt-verify": "^5.1.1",
    "expo": "~55.0.15",
    "expo-clipboard": "~55.0.13",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.27",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.18",
    "expo-linking": "~55.0.13",
    "expo-localization": "~55.0.13",
    "expo-router": "~55.0.12",
    "expo-server": "~55.0.7",
    "expo-splash-screen": "~55.0.18",
    "expo-system-ui": "~55.0.15",
    "expo-video": "~55.0.15",
    "expo-video-thumbnails": "~55.0.14",
    "expo-web-browser": "~55.0.14",
    "heic2any": "^0.0.4",
    "i18next": "^26.0.5",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.3",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2",
    "semver": "^7.7.4",
    "stripe": "^22.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tanstack/eslint-plugin-query": "^5.99.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "eslint": "^10.2.0",
    "eslint-plugin-react": "^7.37.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "globals": "^17.5.0",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "morgan": "^1.10.1",
    "patch-package": "^8.0.1",
    "react-test-renderer": "19.2.0",
    "reactotron-react-native": "^5.1.18",
    "typescript": "~5.9.2"
  },
  "private": true
}
