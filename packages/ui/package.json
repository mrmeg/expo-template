{
  "name": "@mrmeg/expo-ui",
  "version": "0.1.0",
  "private": false,
  "description": "Reusable Expo and React Native UI primitives for MrMeg projects.",
  "license": "UNLICENSED",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*.d.ts",
      "default": "./dist/components/*.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "default": "./dist/constants/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./state": {
      "types": "./dist/state/index.d.ts",
      "default": "./dist/state/index.js"
    },
    "./lib": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --config ../../jest.config.js packages/ui/src --runInBand --watchman=false",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "publish:dry-run": "bun pm pack --dry-run"
  },
  "peerDependencies": {
    "@expo/vector-icons": "*",
    "@react-native-async-storage/async-storage": "*",
    "@rn-primitives/accordion": "*",
    "@rn-primitives/alert-dialog": "*",
    "@rn-primitives/checkbox": "*",
    "@rn-primitives/collapsible": "*",
    "@rn-primitives/dialog": "*",
    "@rn-primitives/dropdown-menu": "*",
    "@rn-primitives/label": "*",
    "@rn-primitives/popover": "*",
    "@rn-primitives/portal": "*",
    "@rn-primitives/radio-group": "*",
    "@rn-primitives/select": "*",
    "@rn-primitives/separator": "*",
    "@rn-primitives/slot": "*",
    "@rn-primitives/switch": "*",
    "@rn-primitives/tabs": "*",
    "@rn-primitives/toggle": "*",
    "@rn-primitives/toggle-group": "*",
    "@rn-primitives/tooltip": "*",
    "@rn-primitives/types": "*",
    "@sentry/react-native": "*",
    "expo": "*",
    "expo-font": "*",
    "expo-haptics": "*",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-reanimated": "*",
    "react-native-safe-area-context": "*",
    "react-native-web": "*",
    "zustand": "*"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "typescript": "~5.9.2"
  }
}
