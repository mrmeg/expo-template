EXPO_UNSTABLE_METRO_OPTIMIZE_GRAPH=1
EXPO_UNSTABLE_TREE_SHAKING=1

EXPO_PUBLIC_API_URL=""
EXPO_PUBLIC_USER_POOL_ID=""
EXPO_PUBLIC_USER_POOL_CLIENT_ID=""

# R2/S3 Storage (required for media uploads)
R2_JURISDICTION_SPECIFIC_URL=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""

# Billing — Client (safe to ship in the JS bundle)
# Turn on the billing UI (pricing CTAs, manage-subscription button). Defaults
# to "false" so projects that don't need Stripe can ignore these vars entirely.
EXPO_PUBLIC_BILLING_ENABLED="false"
# Absolute web origin used to build Stripe Checkout / Portal success + cancel
# URLs when the request doesn't already carry one (e.g. native clients on
# cellular). Leave empty in dev to use the request origin.
EXPO_PUBLIC_APP_URL=""

# Billing — Server (NEVER expose these to client code)
# Stripe secret key (sk_test_… in test mode, sk_live_… in production).
STRIPE_SECRET_KEY=""
# Stripe webhook signing secret (whsec_…). The Stripe CLI prints one when you
# run `stripe listen --forward-to localhost:3000/api/billing/webhook`.
STRIPE_WEBHOOK_SECRET=""
# Price IDs that back the default plan catalog. Leave a value empty to disable
# that plan/interval; the server returns 422 configuration-missing when an
# unconfigured interval is requested.
STRIPE_PRICE_ID_PRO_MONTH=""
STRIPE_PRICE_ID_PRO_YEAR=""
